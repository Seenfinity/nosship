# =============================================================
# NosShip — Environment Variables
# =============================================================
# cp .env.example .env

# LLM — Qwen3.5-27B via Nosana GPU endpoint
OPENAI_API_KEY=nosana
OPENAI_API_URL=https://YOUR_NOSANA_ENDPOINT.node.k8s.prd.nos.ci/v1
OPENAI_BASE_URL=https://YOUR_NOSANA_ENDPOINT.node.k8s.prd.nos.ci/v1
MODEL_NAME=qwen3.5:27b
OPENAI_LARGE_MODEL=qwen3.5:27b
OPENAI_SMALL_MODEL=qwen3.5:27b

# Embeddings
OPENAI_EMBEDDING_URL=https://YOUR_NOSANA_ENDPOINT.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# Server
SERVER_PORT=3000
